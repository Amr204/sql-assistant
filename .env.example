# --------------------------------------------------------------------------
# SQL Assistant — environment variables (Phase 1)
# Copy this file to .env and fill in real values. Never commit .env.
# Only Phase 1 keys are active; LLM / DB / memory keys are placeholders for
# future phases and are intentionally listed here so that ops can plan ahead.
# --------------------------------------------------------------------------

# --- Phase 1 (active) ------------------------------------------------------
APP_ENV=dev                       # dev | staging | prod
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=text                   # text | json

# --- Phase 7 (memory / ChromaDB — now active) ------------------------------
CHROMA_PERSIST_DIR=.data/chroma     # where ChromaDB writes its index files

# --- Future phases (not used yet, kept for visibility) ---------------------
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=
# DATABASE_URL=
# DB_PROFILE_ID=default
