# --------------------------------------------------------------------------
# SQL Assistant — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# --------------------------------------------------------------------------

# --- Phase 1 (active) ------------------------------------------------------
APP_ENV=dev                       # dev | staging | prod
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=text                   # text | json

# --- Phase 10 (startup wiring / runtime profile) ---------------------------
PROFILES_ROOT=profiles
DB_PROFILE_ID=dbnwind

# --- Database connection (required for /agent tools) -----------------------
DB_HOST=127.0.0.1
DB_PORT=1433
DB_DATABASE=DBnwind
DB_USERNAME=readonly_user
DB_PASSWORD=change_me
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=false
DB_CONNECTION_TIMEOUT=10

# --- User resolution --------------------------------------------------------
USER_RESOLVER_MODE=dev              # dev | header | future_oidc
DEV_USER_ID=dev-user
DEV_USER_EMAIL=dev@example.local
DEV_USER_GROUPS=analyst

# --- Memory / context -------------------------------------------------------
CHROMA_PERSIST_DIR=.data/chroma
CONTEXT_MAX_TOKENS=4000

# --- Vanna RunSqlTool CSV exports (default: under .data, never repo root) ---
# VANNA_FILE_STORAGE_DIR=.data/vanna_files

# --- LLM (OpenRouter — wired into Vanna Agent via OpenAILlmService) ---------
# Omit or set LLM_PROVIDER=none to use MockLlmService in the Vanna agent (default).
LLM_PROVIDER=none
#
# Uncomment to enable OpenRouter for the **Vanna** LLM (runtime.vanna.llm_service), not app.state.
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-4o-mini
#
# OPENROUTER_HTTP_REFERER=          # optional; OpenRouter suggests a site URL here
# LLM_HTTP_TIMEOUT_SECONDS=120      # per-request ceiling (5..600 seconds)
