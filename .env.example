# --------------------------------------------------------------------------
# SQL Assistant — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# --------------------------------------------------------------------------

# --- Phase 1 (active) ------------------------------------------------------
APP_ENV=dev                       # dev | staging | prod
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=text                   # text | json
LOG_DIR=logs
LOG_FILE=app.log

# --- Phase 10 (startup wiring / runtime profile) ---------------------------
PROFILES_ROOT=profiles
DB_PROFILE_ID=dbnwind

# --- Database connection (required for /agent tools) -----------------------
DB_HOST=127.0.0.1
DB_PORT=1433
DB_DATABASE=DBnwind
DB_USERNAME=readonly_user
DB_PASSWORD=change_me
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=false
DB_CONNECTION_TIMEOUT=10

# --- User resolution --------------------------------------------------------
USER_RESOLVER_MODE=dev              # dev | header | future_oidc
DEV_USER_ID=dev-user
DEV_USER_EMAIL=dev@example.local
DEV_USER_GROUPS=analyst

# --- Memory / context -------------------------------------------------------
CHROMA_PERSIST_DIR=.data/chroma
CONTEXT_MAX_TOKENS=4000

# --- Vanna RunSqlTool CSV exports (default: under .data, never repo root) ---
# VANNA_FILE_STORAGE_DIR=.data/vanna_files

# --- Model / LLM Provider: OpenAI-compatible API ---------------------------
MODEL_PROVIDER=none
# MODEL_PROVIDER=openai_compatible
# MODEL_API_KEY=
# MODEL_BASE_URL=https://openrouter.ai/api/v1
# MODEL_NAME=openai/gpt-4o-mini
# MODEL_HTTP_REFERER=
MODEL_HTTP_TIMEOUT_SECONDS=120

# Deprecated (still read when MODEL_* unset): LLM_PROVIDER, OPENROUTER_*,
# LLM_HTTP_TIMEOUT_SECONDS
